{
  "name": "familysync",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@4.12.0",
  "description": "FamilySync is a Plex companion service for aggregating linked-user movie ratings.",
  "scripts": {
    "dev": "concurrently \"yarn dev:server\" \"yarn dev:web\"",
    "dev:reset": "tsx scripts/reset-dev-db.ts",
    "dev:server": "tsx watch --tsconfig app/server/tsconfig.json app/server/src/dev.ts",
    "dev:web": "vite --host 0.0.0.0",
    "build": "yarn build:server && yarn build:web",
    "build:server": "tsc -p app/server/tsconfig.json",
    "build:web": "vite build",
    "start": "node dist/server/main.js",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p app/server/tsconfig.json && tsc --noEmit -p app/ui/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "yarn format:check && yarn lint && yarn typecheck && yarn test:coverage && yarn build"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/serve-static": "^5.0.5",
    "@nestjs/typeorm": "^11.0.0",
    "@tailwindcss/vite": "^4.1.8",
    "@vitejs/plugin-react": "^4.5.1",
    "axios": "^1.9.0",
    "better-sqlite3": "^12.10.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "cron": "^4.4.0",
    "fast-xml-parser": "^5.8.0",
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-toastify": "^11.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.24",
    "vite": "^6.3.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1",
    "@types/express": "^5.0.3",
    "@types/node": "^20.14.10",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitest/coverage-v8": "^4.1.8",
    "concurrently": "^9.2.1",
    "eslint": "^9.28.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.5.3",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  }
}
