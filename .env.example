# ─────────────────────────────────────────────────────────────
# FamilySync configuration
#
# Copy this file to `.env`, set APP_ENCRYPTION_KEY, then run:
#   docker compose up -d
#
# Everything else — the Plex server connection, libraries, Radarr/
# Sonarr, thresholds — is configured in the first-run setup wizard
# and the in-app settings. The first Plex account that OWNS the
# server and links becomes the admin.
# ─────────────────────────────────────────────────────────────

# REQUIRED. Encrypts Plex tokens stored in the database. Must be at
# least 32 characters. Generate one with:  openssl rand -hex 32
# Keep this stable — changing it makes existing stored secrets
# unreadable (rotate via APP_ENCRYPTION_KEY_PREVIOUS below).
APP_ENCRYPTION_KEY=

# ── Optional infrastructure ──────────────────────────────────
# Set to the OLD key during a key rotation so existing secrets can
# still be decrypted, then remove once everything is re-encrypted.
# APP_ENCRYPTION_KEY_PREVIOUS=

# Where the SQLite DB + logs are written. docker-compose.yml pins
# this to /config (a named volume); only change it for non-Docker
# runs, where it defaults to ./data.
# CONFIG_DIR=/config

# HTTP port used by the production server. Defaults to 6614.
# PORT=6614

# Public browser URL. When this uses HTTPS, FamilySync automatically marks
# session cookies Secure.
# PUBLIC_URL=https://familysync.example.com

# Override automatic Secure-cookie detection. Set true when TLS terminates at
# a reverse proxy and PUBLIC_URL is unavailable or managed elsewhere.
# COOKIE_SECURE=true

# Trust the first reverse proxy when it supplies forwarded client/protocol
# headers. Leave unset when FamilySync is exposed directly.
# TRUST_PROXY=true
